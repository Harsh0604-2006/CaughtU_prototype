# Example environment configuration for Caught U! Red Agent

# Neo4j AuraDB Configuration
# Get these from your AuraDB instance details
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Gemini API Configuration
# Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# NVD Configuration
# For demo: Use pre-cached JSON to avoid rate limits
# For production: Fetch nightly from NVD API
NVD_API_KEY=
USE_CACHED_NVD=true
NVD_CACHE_PATH=data/nvd_cache.json

# Graph Configuration
SIMULATION_GRAPH=sim
PRODUCTION_GRAPH=prod

# Red Agent Configuration
MAX_ATTACK_VECTORS=5
CRITICALITY_THRESHOLD=High
CVSS_THRESHOLD=7.0
